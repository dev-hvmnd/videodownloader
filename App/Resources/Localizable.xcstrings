          "stringUnit": {
            "state": "translated",
            "value": "Beim ersten Start lädt die App ihre Werkzeuge (Python, ffmpeg, yt-dlp – zusammen ca. 80 MB) nach „Application Support“. Danach ist sie offline einsatzbereit."
          }
        }
      }
    },
